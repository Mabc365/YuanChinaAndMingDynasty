---
---

<section
  class="relative min-h-[100svh] w-full overflow-hidden flex items-center justify-center px-6"
  data-documentary
>
  <!-- film grain -->
  <div class="film-grain" aria-hidden="true"></div>

  <!-- watermark -->
  <div
    class="absolute inset-0 flex items-center justify-center pointer-events-none select-none"
    aria-hidden="true"
  >
    <span
      class="display text-gold tracking-[-0.02em] leading-none"
      style="font-size: min(54vw, 52vh); opacity: 0.04;"
    >
      元明
    </span>
  </div>

  <!-- vignette -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(circle at 50% 50%, transparent 30%, rgba(10,8,4,0.85) 90%);"
    aria-hidden="true"
  ></div>

  <!-- content -->
  <div class="relative z-10 max-w-[620px] w-full text-center flex flex-col items-center gap-8 py-32">
    <!-- play icon -->
    <div class="play-ring">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none" aria-hidden="true">
        <path
          d="M20 14 L44 28 L20 42 Z"
          fill="var(--gold)"
          opacity="0.92"
        />
        <path
          d="M20 14 L44 28 L20 42 Z"
          stroke="var(--gold)"
          stroke-width="1"
          stroke-linejoin="round"
          fill="none"
          opacity="0.6"
        />
      </svg>
    </div>

    <p class="mono text-gold tracking-[0.45em]">元 · 明</p>

    <h1 class="display text-parchment text-5xl md:text-7xl leading-[1.02]">
      The <span class="italic text-gold/90">Documentary</span>
    </h1>

    <div class="rule-diamond max-w-[340px]">
      <span class="diamond"></span>
    </div>

    <p class="text-parchment/75 text-lg md:text-xl max-w-[44ch]">
      A visual journey through four centuries of Yuan and Ming China —
      from steppe conquest to the Forbidden City, from the treasure fleets
      to the final fall of Beijing.
    </p>

    <!-- wax seal -->
    <div class="mt-4">
      <div class="seal">
        <div class="flex flex-col items-center gap-1 leading-none">
          <span class="text-[0.62rem] tracking-[0.4em]">COMING</span>
          <span class="text-xl tracking-[0.25em]">SOON</span>
          <span class="text-[0.55rem] tracking-[0.4em] opacity-80">MMXXVI</span>
        </div>
      </div>
    </div>

    <!-- email capture -->
    <form
      class="w-full max-w-[460px] mt-10"
      data-notify-form
      novalidate
    >
      <label class="mono text-gold/70 block mb-3 text-left">
        Get notified when it drops
      </label>
      <div class="flex border border-gold/30 bg-ink/70 backdrop-blur-sm focus-within:border-gold transition-colors">
        <input
          type="email"
          required
          placeholder="your@email.com"
          class="flex-1 bg-transparent px-4 py-3 text-parchment outline-none placeholder:text-parchment/30"
        />
        <button
          type="submit"
          class="mono text-gold px-5 border-l border-gold/30 hover:bg-gold hover:text-ink transition-colors"
        >
          Notify
        </button>
      </div>
      <p class="mono text-parchment/40 mt-3 text-left" data-notify-msg>
        No spam, just the premiere date.
      </p>
    </form>
  </div>
</section>

<script>
  const initForm = () => {
    const form = document.querySelector<HTMLFormElement>("[data-notify-form]");
    if (!form) return;
    const msg = form.querySelector<HTMLElement>("[data-notify-msg]");
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>("input[type=email]");
      if (!input || !input.value.includes("@")) {
        if (msg) {
          msg.textContent = "That doesn't look like an email.";
          msg.classList.add("text-vermillion");
        }
        return;
      }
      if (msg) {
        msg.textContent = "Sealed in the imperial archives. We'll write.";
        msg.classList.remove("text-vermillion");
        msg.classList.add("text-gold");
      }
      input.value = "";
    });
  };

  initForm();
  document.addEventListener("astro:after-swap", initForm);
</script>
