---
---

<section
  class="relative h-[100svh] w-full overflow-hidden ink-wash"
  data-hero
>
  <!-- Layer 1: drifting characters -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <span class="hero-ch hero-ch--yuan" data-parallax="0.25">元</span>
    <span class="hero-ch hero-ch--ming" data-parallax="0.45">明</span>
  </div>

  <!-- Layer 2: subtle horizon wash -->
  <div
    class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none"
    style="background: linear-gradient(to top, rgba(10,8,4,0.9), transparent);"
    aria-hidden="true"
  ></div>

  <!-- Layer 3: vignette -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at center, transparent 30%, rgba(10,8,4,0.85) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Foreground -->
  <div
    class="relative z-10 h-full flex flex-col justify-center items-center px-6 text-center"
    style="margin-top: -5vh;"
  >
    <h1
      class="display text-parchment leading-[1.02] max-w-[16ch]"
      style="font-size: clamp(3rem, 7vw, 6rem); letter-spacing: 0.04em; text-shadow: 0 0 80px rgba(201,168,76,0.3);"
    >
      From the Steppe<br />
      <span class="italic text-gold/90">to the Sea</span>
    </h1>

    <!-- Thin gold rule between headline and subtitle -->
    <div
      aria-hidden="true"
      style="width: 120px; height: 1px; background: #c9a84c; margin: 1.5rem auto;"
    ></div>

    <p class="hero-subtitle">
      Yuan &nbsp;&middot;&nbsp; Ming &nbsp;&middot;&nbsp; 1271–1644
    </p>

    <div class="rule-diamond mt-10 max-w-[520px]">
      <span class="diamond"></span>
    </div>

    <p class="mt-8 text-parchment/70 text-lg md:text-xl max-w-[44ch]">
      The Yuan &amp; Ming dynasties of imperial China —
      four centuries of conquest, reform, voyage and collapse.
    </p>
  </div>

  <!-- Scroll cue -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10"
    aria-hidden="true"
  >
    <div class="scroll-line"></div>
    <span class="scroll-label">scroll</span>
  </div>
</section>

<script>
  const initHeroParallax = () => {
    const hero = document.querySelector<HTMLElement>("[data-hero]");
    if (!hero) return;

    const layers = Array.from(
      hero.querySelectorAll<HTMLElement>("[data-parallax]")
    );

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const rect = hero.getBoundingClientRect();
        if (rect.bottom < -50) {
          ticking = false;
          return;
        }
        const progress = -rect.top; // px scrolled into the hero
        for (const layer of layers) {
          const speed = parseFloat(layer.dataset.parallax ?? "0.3");
          layer.style.transform = `translate3d(0, ${-progress * speed}px, 0)`;
        }
        ticking = false;
      });
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  };

  initHeroParallax();
  document.addEventListener("astro:after-swap", initHeroParallax);
</script>
