---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Yuan · Ming — 典籍 Archives">
  <section class="sld-head">
    <p class="sld-eyebrow">Yuan &amp; Ming <span>—</span> Archive</p>
    <h1 class="sld-title">
      典籍 <span class="sld-sep">—</span> <em>Archives</em>
    </h1>
    <p class="sld-sub">
      A slide-by-slide passage through the Yuan and Ming dynasties,
      drawn from primary chronicles and modern scholarship.
    </p>
  </section>

  <section class="sld-reader" data-pdf-reader>
    <!-- huge side number (vertical) -->
    <span class="sld-sidenum" data-sld-sidenum aria-hidden="true">1</span>

    <!-- canvas area -->
    <div class="sld-stage">
      <canvas
        class="sld-canvas"
        data-sld-canvas
        aria-label="Slide viewer"
      ></canvas>

      <!-- loading / error overlay -->
      <div class="sld-status" data-sld-status>
        <span class="sld-spinner" aria-hidden="true"></span>
        <span>Loading archive…</span>
      </div>
    </div>

    <!-- controls -->
    <div class="sld-controls">
      <span class="sld-counter">
        <span data-sld-curr>01</span>
        <span class="sld-counter-slash">/</span>
        <span data-sld-total>--</span>
      </span>

      <div class="sld-nav">
        <button type="button" class="sld-arrow" data-sld-prev aria-label="Previous slide">
          <svg width="34" height="18" viewBox="0 0 34 18" fill="none">
            <path
              d="M33 9 H2 M9 2 L2 9 L9 16"
              stroke="currentColor"
              stroke-width="1"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
        <button type="button" class="sld-arrow" data-sld-next aria-label="Next slide">
          <svg width="34" height="18" viewBox="0 0 34 18" fill="none">
            <path
              d="M1 9 H32 M25 2 L32 9 L25 16"
              stroke="currentColor"
              stroke-width="1"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
      </div>

      <a href="/slideshow.pdf" download class="sld-download">
        ↓ Download
      </a>
    </div>

    <p class="sld-note">
      Use the chevrons or your ← → keys to turn the page.
    </p>
  </section>
</BaseLayout>

<style>
  .sld-head {
    padding: 10rem 1.5rem 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .sld-eyebrow {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    color: rgba(201, 168, 76, 0.75);
    font-size: 0.68rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
  }
  .sld-eyebrow span { opacity: 0.5; margin: 0 0.5rem; }

  .sld-title {
    font-family: "Noto Serif SC", serif;
    font-weight: 500;
    color: #e8dcc8;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-top: 1rem;
    line-height: 1.05;
  }
  .sld-title em {
    font-family: "Cormorant Garamond", serif;
    font-style: italic;
    color: #c9a84c;
    font-weight: 500;
  }
  .sld-sep { color: rgba(201, 168, 76, 0.5); margin: 0 0.35em; }

  .sld-sub {
    color: rgba(232, 220, 200, 0.65);
    font-family: "Cormorant Garamond", serif;
    font-size: 1.15rem;
    font-style: italic;
    margin-top: 1.25rem;
    max-width: 60ch;
  }

  /* ————— reader ————— */
  .sld-reader {
    position: relative;
    padding: 0 1.5rem 6rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .sld-sidenum {
    position: absolute;
    left: 1rem;
    top: 8rem;
    font-family: "Noto Serif SC", serif;
    font-weight: 600;
    font-size: 8vw;
    line-height: 1;
    color: #c9a84c;
    opacity: 0.06;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    user-select: none;
    pointer-events: none;
  }

  .sld-stage {
    position: relative;
    width: 85vw;
    max-width: 1100px;
    margin: 0 auto;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sld-canvas {
    display: block;
    width: 100%;
    height: auto;
    background: #0a0804;
    box-shadow:
      0 0 0 1px rgba(201, 168, 76, 0.25),
      0 30px 80px -40px rgba(0, 0, 0, 0.9);
    transition: opacity 0.3s ease;
    opacity: 0;
  }
  .sld-canvas.is-ready { opacity: 1; }

  .sld-status {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    color: rgba(232, 220, 200, 0.55);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .sld-status.is-hidden { opacity: 0; }
  .sld-status.is-error {
    color: #c0392b;
  }
  .sld-spinner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid rgba(201, 168, 76, 0.25);
    border-top-color: #c9a84c;
    animation: sld-spin 0.9s linear infinite;
  }
  @keyframes sld-spin { to { transform: rotate(360deg); } }

  /* ————— controls ————— */
  .sld-controls {
    max-width: 1100px;
    margin: 2rem auto 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .sld-counter {
    font-family: "Cormorant Garamond", serif;
    color: #c9a84c;
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .sld-counter-slash { opacity: 0.4; }

  .sld-nav {
    display: inline-flex;
    align-items: center;
    gap: 2.25rem;
    justify-content: center;
  }
  .sld-arrow {
    background: transparent;
    border: 0;
    color: #c9a84c;
    padding: 0.5rem;
    cursor: pointer;
    transition: color 0.25s, transform 0.25s;
  }
  .sld-arrow:hover { color: #c0392b; }
  .sld-arrow:active { transform: scale(0.94); }
  .sld-arrow[disabled] {
    opacity: 0.25;
    cursor: default;
  }
  .sld-arrow[disabled]:hover { color: #c9a84c; }

  .sld-download {
    justify-self: end;
    color: #c9a84c;
    text-decoration: none;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    padding: 0.5rem 0.25rem;
    transition: color 0.25s;
  }
  .sld-download:hover { color: #c0392b; }

  .sld-note {
    color: rgba(232, 220, 200, 0.38);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    text-align: center;
    margin-top: 2.5rem;
  }

  @media (max-width: 768px) {
    .sld-head { padding: 7rem 1.25rem 2rem; }
    .sld-stage { width: 100%; }
    .sld-sidenum { display: none; }
    .sld-controls { grid-template-columns: 1fr; gap: 1.5rem; justify-items: center; }
    .sld-download { justify-self: center; }
  }
</style>

<!-- PDF.js from CDN (global window.pdfjsLib) -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

<script>
  const WORKER_URL =
    "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";

  // set worker src as soon as pdf.js is available, before any getDocument call
  if ((window as any).pdfjsLib) {
    (window as any).pdfjsLib.GlobalWorkerOptions.workerSrc = WORKER_URL;
  }

  const initReader = async () => {
    const canvas = document.querySelector<HTMLCanvasElement>("[data-sld-canvas]");
    const status = document.querySelector<HTMLElement>("[data-sld-status]");
    const currEl = document.querySelector<HTMLElement>("[data-sld-curr]");
    const totalEl = document.querySelector<HTMLElement>("[data-sld-total]");
    const sideEl = document.querySelector<HTMLElement>("[data-sld-sidenum]");
    const prevBtn = document.querySelector<HTMLButtonElement>("[data-sld-prev]");
    const nextBtn = document.querySelector<HTMLButtonElement>("[data-sld-next]");
    if (!canvas || !status || !currEl || !totalEl || !prevBtn || !nextBtn) return;

    const pdfjsLib = (window as any).pdfjsLib;
    if (!pdfjsLib) {
      status.textContent = "PDF.js failed to load.";
      status.classList.add("is-error");
      return;
    }
    pdfjsLib.GlobalWorkerOptions.workerSrc = WORKER_URL;

    // absolute URL so Vercel's edge fetches from the same origin at runtime
    const PDF_URL = `${window.location.origin}/slideshow.pdf`;

    let gsap: any = null;
    try {
      gsap = (await import("https://cdn.skypack.dev/gsap")).default;
    } catch { /* fall through to CSS transition */ }

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const pad = (n: number) => String(n).padStart(2, "0");

    let pdfDoc: any = null;
    let currentPage = 1;
    let renderTask: any = null;

    const renderPage = async (pageNum: number) => {
      if (!pdfDoc) return;

      // fade out
      if (gsap) {
        await new Promise<void>((resolve) =>
          gsap.to(canvas, {
            opacity: 0,
            duration: 0.22,
            ease: "power2.out",
            onComplete: () => resolve(),
          })
        );
      } else {
        canvas.classList.remove("is-ready");
        await new Promise((r) => setTimeout(r, 180));
      }

      const page = await pdfDoc.getPage(pageNum);

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const stage = canvas.parentElement as HTMLElement;
      const stageWidth = stage.clientWidth;

      const baseViewport = page.getViewport({ scale: 1 });
      const cssScale = stageWidth / baseViewport.width;
      const viewport = page.getViewport({ scale: cssScale * dpr });

      canvas.width = viewport.width;
      canvas.height = viewport.height;
      canvas.style.width = `${viewport.width / dpr}px`;
      canvas.style.height = `${viewport.height / dpr}px`;

      if (renderTask && typeof renderTask.cancel === "function") {
        renderTask.cancel();
      }
      renderTask = page.render({ canvasContext: ctx, viewport });
      try {
        await renderTask.promise;
      } catch (err: any) {
        if (err && err.name === "RenderingCancelledException") return;
        throw err;
      }

      currEl.textContent = pad(pageNum);
      if (sideEl) sideEl.textContent = String(pageNum);

      prevBtn.disabled = pageNum <= 1;
      nextBtn.disabled = pageNum >= pdfDoc.numPages;

      // fade in
      if (gsap) {
        gsap.to(canvas, { opacity: 1, duration: 0.3, ease: "power2.out" });
      } else {
        canvas.classList.add("is-ready");
      }
    };

    const goTo = (target: number) => {
      if (!pdfDoc) return;
      const clamped = Math.max(1, Math.min(pdfDoc.numPages, target));
      if (clamped === currentPage) return;
      currentPage = clamped;
      renderPage(currentPage).catch((err) => console.error(err));
    };

    prevBtn.addEventListener("click", () => goTo(currentPage - 1));
    nextBtn.addEventListener("click", () => goTo(currentPage + 1));

    const onKey = (e: KeyboardEvent) => {
      if (e.key === "ArrowRight") goTo(currentPage + 1);
      else if (e.key === "ArrowLeft") goTo(currentPage - 1);
    };
    window.addEventListener("keydown", onKey);

    const onResize = () => {
      if (pdfDoc) renderPage(currentPage).catch(() => {});
    };
    let resizeTimer: any = null;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(onResize, 180);
    });

    // cleanup on view-transition swap
    const cleanup = () => {
      window.removeEventListener("keydown", onKey);
      if (renderTask && typeof renderTask.cancel === "function") renderTask.cancel();
      document.removeEventListener("astro:before-swap", cleanup);
    };
    document.addEventListener("astro:before-swap", cleanup);

    try {
      const loadingTask = pdfjsLib.getDocument({
        url: PDF_URL,
        withCredentials: false,
      });
      pdfDoc = await loadingTask.promise;
      totalEl.textContent = pad(pdfDoc.numPages);
      status.classList.add("is-hidden");
      await renderPage(1);
    } catch (err) {
      console.error(err);
      status.innerHTML = "Archive unavailable.";
      status.classList.add("is-error");
    }
  };

  initReader();
  document.addEventListener("astro:after-swap", initReader);
</script>
